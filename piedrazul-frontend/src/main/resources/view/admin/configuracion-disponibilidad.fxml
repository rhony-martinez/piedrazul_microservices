<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>

<VBox spacing="12"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.piedrazul.frontend.controller.ConfiguracionDisponibilidadController">

    <Label text="Configurar Disponibilidad" styleClass="title"/>

    <ComboBox fx:id="cmbMedicos" promptText="Seleccione médico"/>
    <ComboBox fx:id="cmbDiaSemana" promptText="Día"/>

    <HBox spacing="10">
        <TextField fx:id="txtHoraInicio" promptText="08:00"/>
        <TextField fx:id="txtHoraFin" promptText="10:00"/>
    </HBox>

    <TextField fx:id="txtIntervalo" promptText="Intervalo (minutos)"/>

    <Button text="Agregar Disponibilidad" onAction="#handleAgregar"/>

    <!-- TABLA -->
    <TableView fx:id="tablaDisponibilidad" prefHeight="200">
        <columns>
            <TableColumn fx:id="colMedico" text="Médico"/>
            <TableColumn fx:id="colDia" text="Día"/>
            <TableColumn fx:id="colHoraInicio" text="Inicio"/>
            <TableColumn fx:id="colHoraFin" text="Fin"/>
            <TableColumn fx:id="colIntervalo" text="Intervalo"/>
        </columns>
    </TableView>

    <!-- BOTÓN VOLVER -->
    <Button text="Volver al Dashboard"
            onAction="#handleVolver"
            styleClass="dashboard-secondary-button"/>

</VBox>