<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.piedrazul.frontend.controller.LoginController"
            stylesheets="@login.css"
            styleClass="root">

    <!-- 🔵 HEADER -->
    <top>
        <HBox styleClass="header">
            <Label text="PIEDRAZUL" styleClass="logo"/>
        </HBox>
    </top>

    <!-- 🧾 CONTENIDO -->
    <center>
        <VBox alignment="CENTER" spacing="25" styleClass="container">

            <Label text="INICIAR SESIÓN" styleClass="title"/>

            <!-- FORMULARIO -->
            <GridPane hgap="20" vgap="20" styleClass="form">

                <!-- Usuario -->
                <Label text="Usuario" styleClass="label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>

                <HBox spacing="10" styleClass="input-container"
                      GridPane.rowIndex="0" GridPane.columnIndex="1">

                    <Label text="👤" styleClass="input-icon"/>
                    <TextField fx:id="txtUsername"
                               promptText="Ingrese su usuario"
                               styleClass="input"/>

                </HBox>

                <!-- Contraseña -->
                <Label text="Contraseña" styleClass="label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                <HBox spacing="10" styleClass="input-container"
                      GridPane.rowIndex="1" GridPane.columnIndex="1">

                    <Label text="🔒" styleClass="input-icon"/>
                    <PasswordField fx:id="txtPassword"
                                   promptText="Ingrese su contraseña"
                                   styleClass="input"/>

                </HBox>

            </GridPane>

            <!-- BOTÓN PRINCIPAL -->
            <Button text="Iniciar Sesión"
                    onAction="#handleLogin"
                    styleClass="btn-primary"/>

            <!-- ACCIÓN SECUNDARIA -->
            <Button text="Registrar"
                    onAction="#onGoRegister"
                    styleClass="btn-secondary"/>

            <!-- MENSAJE -->
            <Label fx:id="lblMensaje" styleClass="error-label"/>

        </VBox>
    </center>

</BorderPane>